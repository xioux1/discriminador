HOST=0.0.0.0
PORT=3000
DATABASE_URL=postgres://postgres:postgres@localhost:5432/discriminador
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...
JWT_SECRET=change-this-to-a-random-64-character-string

# Database pool (optional — defaults shown)
DB_POOL_MAX=10
DB_POOL_IDLE_TIMEOUT_MS=30000
DB_POOL_CONN_TIMEOUT_MS=5000

# LLM rate limiting per user (optional — defaults shown)
LLM_RATE_LIMIT_REQUESTS=30
LLM_RATE_LIMIT_WINDOW_MS=60000
