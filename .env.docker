# Copy this file and fill in your keys
# docker compose --env-file .env.docker up --build
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...        # still needed for concept embeddings
DEEPGRAM_API_KEY=...         # speech-to-text (/transcribe) and TTS (/tts)
JWT_SECRET=change-this-to-a-long-random-string-at-least-32-chars

# Optional: override Deepgram TTS voice models
# DEEPGRAM_TTS_VOICE_ES=aura-asteria-en
# DEEPGRAM_TTS_VOICE_ZH=aura-asteria-en
